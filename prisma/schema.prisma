// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Teacher {
  id                String             @id @default(cuid())
  name              String
  nickname          String
  seniority         Seniority 
  rank              Int
  maxLoad           Int
  // preferredTimeSlots String[] // [cite: 21] (optional, can be implemented later)
  offeredToTeachers OfferedToTeacher[]
}

enum Seniority {
  Lecturer
  AssistantProfessor
  AssociateProfessor
  Professor
}

model Classroom {
  id       String        @id @default(cuid())
  name     String
  code     String
  capacity Int
  type     ClassroomType @default(Theory)

  sections Section[]
}

enum ClassroomType {
  Theory
  Lab
  ComputerLab
}

model Section {
  id               String      @id @default(cuid())
  code             String
  department       Departments
  numberOfStudents Int
  homeClassroomId  String      @unique
  homeClassroom    Classroom   @relation(fields: [homeClassroomId], references: [id])
}

// offered to multiple departments
//        cross-listed courses
// offered by multiple teachers
//        co-taught courses

model Course {
  id          String      @id @default(cuid())
  title       String
  shortCode   String
  creditHours Float
  offeredTo   OfferedTo[]
  type        CourseType
  duration    Int
}

model OfferedTo {
  id         String      @id @default(cuid())
  courseId   String
  department Departments
  term       Terms

  course Course @relation(fields: [courseId], references: [id])

  offeredToTeachers OfferedToTeacher[]
}

model OfferedToTeacher {
  id          String @id @default(cuid())
  offeredToId String
  teacherId   String

  offeredTo OfferedTo @relation(fields: [offeredToId], references: [id])
  teacher   Teacher   @relation(fields: [teacherId], references: [id])
}

enum Terms {
  L1_T1
  L1_T2
  L2_T1
  L2_T2
  L3_T1
  L3_T2
  L4_T1
  L4_T2
}

enum CourseType {
  Theory
  Lab
  ComputerLab
}

enum Departments {
  CSE
  EEE
  ME
  CE
  ARCH
  BME
  URP
  NAME
  MME
  CHEM
  IPE
  NCE
  WRE
}
